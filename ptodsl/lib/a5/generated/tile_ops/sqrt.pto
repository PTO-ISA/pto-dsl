      %16 = pto.vsqrt %15, %14 : !pto.vreg<64xf32>, !pto.mask -> !pto.vreg<64xf32>
      pto.vsts %16, %7[%c128], %14 : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask
