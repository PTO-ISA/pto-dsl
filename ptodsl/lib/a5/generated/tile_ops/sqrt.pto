      %19 = pto.vsqrt %18, %17 : !pto.vreg<64xf32>, !pto.mask -> !pto.vreg<64xf32>
      pto.vsts %19, %7[%c192], %17 : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask
      %20 = pto.pset_b32 "PAT_ALL" : !pto.mask
      %c256 = arith.constant 256 : index
