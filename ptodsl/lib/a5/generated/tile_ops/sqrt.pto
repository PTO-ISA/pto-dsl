      %13 = pto.vsqrt %12, %11 : !pto.vreg<64xf32>, !pto.mask -> !pto.vreg<64xf32>
      pto.vsts %13, %7[%c64_13], %11 : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask
      %14 = pto.pset_b32 "PAT_ALL" : !pto.mask
      %c128 = arith.constant 128 : index
