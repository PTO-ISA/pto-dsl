      %9 = pto.partition_view %2, offsets = [%c0_12, %c0_13], sizes = [%c16_14, %c32_15] : !pto.tensor_view<?x?xf16> -> !pto.partition_tensor_view<16x32xf16>
      %10 = pto.alloc_tile : !pto.tile_buf<mat, 16x32xf16, blayout=col_major, slayout=row_major>
